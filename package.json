{
  "name": "web-title-pro",
  "version": "0.4.4",
  "description": "Low-latency web title control system for vMix Browser Input",
  "type": "module",
  "main": "desktop/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "nodemon --watch server --watch package.json --ext js,json server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "node server/index.js",
    "desktop": "npm run build && node scripts/run-desktop.cjs",
    "desktop:dev": "node scripts/run-desktop.cjs",
    "package:win": "npm run build && electron-builder --win portable && node scripts/finalize-portable.cjs",
    "test": "node --test tests/*.test.js",
    "test:unit": "node --test tests/*.test.js",
    "test:ui": "playwright test",
    "test:ui:install": "playwright install chromium",
    "test:all": "npm run test:unit && npm run build && npm run test:ui"
  },
  "keywords": [
    "vmix",
    "broadcast",
    "title",
    "lower-third",
    "electron",
    "obs"
  ],
  "author": "perogello",
  "license": "MIT",
  "homepage": "https://github.com/perogello/Web-Title-Pro",
  "repository": {
    "type": "git",
    "url": "https://github.com/perogello/Web-Title-Pro.git"
  },
  "bugs": {
    "url": "https://github.com/perogello/Web-Title-Pro/issues"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.14",
    "vite": "^8.0.3"
  },
  "dependencies": {
    "archiver": "^8.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "fs-extra": "^11.3.4",
    "jsdom": "^24.1.3",
    "jzz": "^1.9.6",
    "multer": "^2.1.1",
    "nanoid": "^5.1.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "unzipper": "^0.12.3",
    "ws": "^8.20.0",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.webtitlepro.desktop",
    "productName": "Web Title Pro",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "desktop/**/*",
      "renderer/**/*",
      "server/**/*",
      "templates/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "desktop/main.cjs"
    },
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "WebTitlePro-${version}.${ext}",
      "icon": "build/icon.ico"
    }
  }
}
