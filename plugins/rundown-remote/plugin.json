{
  "name": "Rundown Remote",
  "version": "1.0.0",
  "description": "A minimal reference plugin: shows the first output's current row and title state, and steps rows / takes the title in and out through the command bus.",
  "author": "Web Title Pro",
  "entry": "index.html",
  "capabilities": ["state:read", "command:send"],
  "mount": { "type": "panel", "location": "live", "label": "Rundown Remote" },
  "contributes": {
    "buttons": [
      { "slot": "live.toolbar", "label": "PANIC", "command": "global:allOutputsOut" },
      { "slot": "live.toolbar", "label": "Row + Show", "action": "takeNext" }
    ],
    "commands": [
      { "id": "takeNext", "label": "Advance data row and take the title to air" }
    ]
  },
  "settings": [
    { "key": "heading", "label": "Заголовок панели", "type": "text", "default": "Rundown Remote" },
    { "key": "showRowButtons", "label": "Кнопки листания строк", "type": "checkbox", "default": true },
    {
      "key": "accent",
      "label": "Акцент кнопки IN",
      "type": "select",
      "default": "green",
      "options": [
        { "value": "green", "label": "Зелёный" },
        { "value": "blue", "label": "Синий" },
        { "value": "amber", "label": "Янтарный" }
      ]
    }
  ]
}
